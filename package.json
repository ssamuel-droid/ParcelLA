{
  "name": "parcella",
  "version": "3.0.0",
  "description": "Los Angeles Development Site Marketplace — Pre-underwriting search engine",
  "type": "module",
  "main": "api/server.js",
  "scripts": {
    "start": "NODE_ENV=production node api/server.js",
    "dev": "NODE_ENV=development node --watch api/server.js",
    "sync": "node api/jobs/sync.js --run-now",
    "test-apis": "python scripts/test_apis.py",
    "db:migrate": "echo 'Paste supabase/schema.sql into Supabase SQL editor and click Run'",
    "excel": "python scripts/generate_excel.py",
    "build": "vite build",
    "preview": "vite preview",
    "dev:frontend": "vite",
    "dev:api": "NODE_ENV=development node --watch api/server.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "node-cron": "^3.0.3",
    "puppeteer": "^21.11.0",
    "resend": "^2.1.0",
    "stripe": "^14.21.0",
    "@googlemaps/js-api-loader": "^1.16.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "vite": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}