# ─────────────────────────────────────────────────────────────────────────────
# ParceLLA — Environment Variables
# Copy to .env — never commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── FREE: Supabase (database + auth) ─────────────────────────────────────────
# https://supabase.com → new project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5c...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5c...

# ── Google Maps Platform ──────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs → Enable:
#   Maps JavaScript API, Geocoding API, Street View Static API
# Free tier: $200/mo credit (~28K map loads free)
# One key covers all three APIs
GOOGLE_MAPS_API_KEY=AIzaSy...
VITE_GOOGLE_MAPS_API_KEY=AIzaSy...   # same key — used in frontend build

# ── FREE: LA City Open Data (Socrata) ────────────────────────────────────────
# https://data.lacity.org/profile/edit/developer_settings
# Without token: 1,000 req/day. With token: unlimited.
SOCRATA_APP_TOKEN=

# ── FREE: US Census Bureau ────────────────────────────────────────────────────
# https://api.census.gov/data/key_signup.html
# Unlocks: ACS demographics, median income, renter % by tract
CENSUS_API_KEY=

# ── Anthropic Claude API (AI deal narratives) ────────────────────────────────
# https://console.anthropic.com → API Keys
# Pay-as-you-go: ~$0.01 per narrative
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Resend (email — $0 for 3K/mo) ────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Stripe (subscriptions) ───────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
# Use sk_test_xxx for testing, sk_live_xxx for production
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRO_PRICE_ID=price_xxxx         # $49/mo — create in Stripe dashboard
STRIPE_ENTERPRISE_PRICE_ID=price_xxxx  # $199/mo

# ── RentCast (live rent comps — ~$50/mo) ─────────────────────────────────────
# https://app.rentcast.io/app/api
RENTCAST_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:3000
# Production: APP_URL=https://parcella.com
# Comma-separated allowed CORS origins:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://parcella.com
