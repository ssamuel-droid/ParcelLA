# ─────────────────────────────────────────────────────────────
# ParceLLA — Environment Variables
# Copy to .env and fill in your keys. Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── FREE: LA City Open Data (Socrata) ───────────────────────
# Register at: https://data.lacity.org/profile/edit/developer_settings
# Unlocks: LADBS permits, RTI status, zoning, RSO, building cases
# Without token: 1,000 req/day. With token: unlimited.
SOCRATA_APP_TOKEN=

# ── FREE: US Census Bureau ───────────────────────────────────
# Register at: https://api.census.gov/data/key_signup.html
# Unlocks: median income, renter %, demographics by tract
CENSUS_API_KEY=

# ── FREE tier: Mapbox ────────────────────────────────────────
# Register at: https://account.mapbox.com/auth/signup/
# Free tier: 50,000 map loads/month
# Unlocks: real LA street map, geocoding, parcel overlays
MAPBOX_TOKEN=

# ── FREE tier: Supabase ──────────────────────────────────────
# Register at: https://supabase.com
# Free tier: 500MB DB, 50K monthly active users
# Unlocks: user auth, saved sites, deal alerts, PostgreSQL+PostGIS
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── PAID: RentCast rent comps (~$50/mo) ──────────────────────
# Register at: https://app.rentcast.io/app/api
# Unlocks: live rent estimates by zip + bedroom count
RENTCAST_API_KEY=

# ── PAID: CoStar / LoopNet (~$3–8K/mo) ──────────────────────
# Contact: https://www.costar.com/about/contact-us
COSTAR_API_KEY=

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
