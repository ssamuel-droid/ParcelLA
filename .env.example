# ─────────────────────────────────────────────────────────────────────────────
# ParceLLA — Environment Variables v2
# Copy to .env — never commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── FREE: Supabase (database + auth) ─────────────────────────────────────────
# https://supabase.com → new project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5c...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5c...

# ── FREE: LA City Open Data (Socrata) ────────────────────────────────────────
# https://data.lacity.org/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# ── FREE: US Census Bureau ────────────────────────────────────────────────────
# https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# ── FREE tier: Mapbox ─────────────────────────────────────────────────────────
# https://account.mapbox.com → Tokens → Default public token (starts with pk.)
MAPBOX_TOKEN=pk.eyJ1IjoieW91cnVzZXJuYW1lIiwiYSI6...

# ── Anthropic (Claude API — AI narratives) ────────────────────────────────────
# https://console.anthropic.com → API Keys
# Pay-as-you-go: ~$0.01 per narrative (~400 tokens in, ~450 out)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── PAID: Resend (email) — $0 for 3K/mo ──────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── PAID: Stripe (subscriptions) ─────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_xxxx         # use sk_test_xxx for testing
STRIPE_WEBHOOK_SECRET=whsec_xxxx       # from Stripe → Webhooks → endpoint secret
# Create these in Stripe dashboard → Products:
STRIPE_PRO_PRICE_ID=price_xxxx         # $49/mo recurring
STRIPE_ENTERPRISE_PRICE_ID=price_xxxx  # $199/mo recurring

# ── PAID: RentCast rent comps (~$50/mo) ───────────────────────────────────────
# https://app.rentcast.io/app/api
RENTCAST_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:3000
# Comma-separated allowed origins for CORS:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://parcella.com
