# ParceLLA Environment Variables
# Copy to .env and fill in your keys

# LA City / County Open Data (free — register at data.lacity.org)
SOCRATA_APP_TOKEN=

# Zillow rent comps via Bridge Data Output (~$200/mo)
ZILLOW_API_KEY=

# CoStar API (enterprise — contact CoStar Group)
COSTAR_API_KEY=

# Database (PostgreSQL + PostGIS recommended)
DATABASE_URL=postgresql://localhost:5432/parcella

# Auth (Supabase recommended — free tier available)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server
PORT=3001
NODE_ENV=development
